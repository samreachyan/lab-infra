{
  "title": "JVM & Application Metrics",
  "uid": "jvm-metrics",
  "version": 1,
  "tags": ["mission", "jvm", "spring"],
  "schemaVersion": 39,
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "title": "JVM Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=~\"$application\"}) by (application)",
          "legendFormat": "{{application}} - Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=~\"$application\"}) by (application)",
          "legendFormat": "{{application}} - Max",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "JVM GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=~\"$application\"}[1m])",
          "legendFormat": "{{application}} - {{cause}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=~\"$application\"}[1m])",
          "legendFormat": "{{application}} - {{method}} {{uri}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "HTTP Request Duration (P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=~\"$application\"}[1m]))",
          "legendFormat": "{{application}} - {{method}} {{uri}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=~\"$application\"}",
          "legendFormat": "{{application}} - {{area}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Log Rate by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(logback_events_total{application=~\"$application\"}[1m])",
          "legendFormat": "{{application}} - {{level}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "showPoints": "never" }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "query": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ]
  }
}
